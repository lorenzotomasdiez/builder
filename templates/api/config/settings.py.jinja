{# Config
# Jinja - Pydantic Settings

from pydantic_settings import BaseSettings
from pydantic import Field
from typing import Optional


class Settings(BaseSettings):
    PROJECT_NAME: str = Field(default="{{ PROJECT_NAME }}")
    
    # Database
    DATABASE_URL: str = Field(
        default="postgresql+asyncpg://postgres:postgres@localhost:5432/{{ PROJECT_NAME }}"
    )
    
    # JWT
    SECRET_KEY: str = Field(default="change-me-in-production")
    ALGORITHM: str = Field(default="HS256")
    ACCESS_TOKEN_EXPIRE_MINUTES: int = Field(default={{ ACCESS_TOKEN_EXPIRE_MINUTES|default(30) }})
    REFRESH_TOKEN_EXPIRE_DAYS: int = Field(default={{ REFRESH_TOKEN_EXPIRE_DAYS|default(7) }})
    
    # App
    DEBUG: bool = Field(default=True)
    API_V1_PREFIX: str = Field(default="/api/v1")
    
    # CORS
    BACKEND_CORS_ORIGINS: list[str] = Field(default=["*"])
    
    class Config:
        case_sensitive = True
